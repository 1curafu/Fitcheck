# Supabase (EU region project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only, never expose with NEXT_PUBLIC

# Anthropic — used server-side in tagging/reasoning Server Actions (plans 04 + 06)
ANTHROPIC_API_KEY=

# Google OAuth — read by supabase/config.toml via env() for local auth.
# Source this file before `supabase start`: set -a; source .env.local; set +a
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
